<div id="<%= dom_id winery %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Name:</strong>
    <%= winery.name %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Location:</strong>
    <%= winery.location_id %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this winery", winery, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to "Edit this winery", edit_winery_path(winery), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
